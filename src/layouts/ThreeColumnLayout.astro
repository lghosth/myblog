---
import "@/styles/layout-common.css";
import "@/styles/layout-three-column.css";
import type { CollectionEntry } from "astro:content";
import type { NavItemType } from "@/components/navbar/NavTypes";
import type {
  TocItem,
  RelatedPost,
  QuickNavigation,
  SidebarConfig,
} from "@/components/sidebar/SidebarTypes";
import RightSidebar from "@/components/sidebar/RightSidebar.astro";
import LayoutMainColumn from "./shared/LayoutMainColumn.astro";
import LayoutPrimarySidebar from "./shared/LayoutPrimarySidebar.astro";

interface WidgetsConfig {
  randomPosts?: boolean;
  recentComments?: boolean;
  recentCommentsLimit?: number;
}

interface Props {
  posts: CollectionEntry<"posts">[];
  widgetsConfig?: WidgetsConfig;
  commentsEnabled?: boolean;
  walineServerURL?: string;
  footerConfig?: any;
  siteName: string;
  author?: string;
  sidebarConfig?: SidebarConfig;
  rightSidebarConfig?: {
    order?: Array<
      | "announcement"
      | "search"
      | "calendar"
      | "recentMoments"
      | "randomPosts"
      | "tagCloud"
    >;
    search?: boolean;
    calendar?: boolean;
    recentMoments?: boolean;
    randomPosts?: boolean;
    tagCloud?: boolean;
    announcement?: boolean;
  };
  rightSidebarPosts?: CollectionEntry<"posts">[];
  rightSidebarMoments?: CollectionEntry<"moments">[];
  rightSidebarTagCloud?: Array<{
    name: string;
    count: number;
    fontSize: number;
    color: string;
    href: string;
  }>;
  navLinks?: NavItemType[];
  toc?: TocItem[];
  relatedPosts?: RelatedPost[];
  currentSlug?: string;
  navigation?: QuickNavigation;
  siteState: {
    categories: number;
    posts: number;
    tags: number;
  };
}

const {
  posts,
  widgetsConfig = {},
  commentsEnabled = false,
  walineServerURL = "",
  footerConfig = {},
  siteName,
  author = "",
  sidebarConfig,
  rightSidebarConfig = {},
  rightSidebarPosts = [],
  rightSidebarMoments = [],
  rightSidebarTagCloud = [],
  navLinks = [],
  toc = [],
  relatedPosts = [],
  currentSlug = "",
  navigation = {},
  siteState,
} = Astro.props;
---

<div class="inner layout-frame layout-three-column">
  <LayoutPrimarySidebar
    config={sidebarConfig}
    {navLinks}
    {toc}
    {relatedPosts}
    {currentSlug}
    {navigation}
    {siteState}
  />
  <LayoutMainColumn
    {posts}
    {widgetsConfig}
    {commentsEnabled}
    {walineServerURL}
    {footerConfig}
    {siteName}
    {author}
  >
    <slot />
  </LayoutMainColumn>
  <RightSidebar
    config={rightSidebarConfig}
    posts={rightSidebarPosts}
    moments={rightSidebarMoments}
    tagCloudItems={rightSidebarTagCloud}
  />
</div>
