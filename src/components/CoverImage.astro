---
import SmartImage from "./SmartImage.astro";
import type { ImageSource } from "@/toolkit/images/imageSource";

interface Props {
  src: ImageSource;
  alt: string;
  index: number;
  isListItem?: boolean;
}

const { src, alt, index, isListItem = false } = Astro.props as Props;

// 动画延迟(仅多图轮播)
const animationDelay = isListItem ? `${index * 6}s` : "0s";
---

{
  isListItem ? (
    <li
      class="cover-item"
      style={`animation-delay: ${animationDelay};`}
      onmouseenter="this.classList.add('stop-animation')"
      onmouseleave="this.classList.remove('stop-animation')"
      ontouchstart="this.classList.add('stop-animation')"
      ontouchend="this.classList.remove('stop-animation')"
    >
      <SmartImage
        src={src}
        alt={alt}
        class="cover-image"
        loading="eager"
        decoding="async"
        fetchpriority="high"
        layout="constrained"
        format="avif"
        priority={true}
        quality={65}
      />
    </li>
  ) : (
    <SmartImage
      src={src}
      alt={alt}
      class="single-image"
      loading="eager"
      decoding="sync"
      fetchpriority="high"
      layout="constrained"
      format="avif"
      priority={true}
    />
  )
}

<style>
  .cover-item {
    opacity: 0;
    height: 70vh;
    width: 100%;
    left: 0;
    top: 0;
    position: absolute;
    z-index: var(--z-base);
    overflow: hidden;
    animation: imageAnimation 36s linear infinite 0s;
    backface-visibility: hidden;
    transform-style: preserve-3d;
  }

  .cover-item.stop-animation {
    animation-play-state: paused;
  }

  .cover-image {
    height: 100%;
    width: 100%;
    object-fit: cover;
  }

  .single-image {
    height: 100%;
    width: 100%;
    left: 0;
    top: 0;
    position: absolute;
    object-fit: cover;
  }

  /* 动画应用到容器上，图片本身用 object-cover 填充 */
  .cover-item :global(img) {
    transform-origin: center;
  }

  @keyframes imageAnimation {
    0% {
      opacity: 0;
      animation-timing-function: ease-in;
    }
    2% {
      opacity: 1;
    }
    8% {
      opacity: 1;
      transform: scale(1.05);
      animation-timing-function: ease-out;
    }
    17% {
      opacity: 1;
      transform: scale(1.1);
    }
    25% {
      opacity: 0;
      transform: scale(1.1);
    }
    100% {
      opacity: 0;
    }
  }
</style>
