---
import { getT } from "@/i18n";
import themeConfig from "@/theme.config";
import type { CollectionEntry } from "astro:content";
import SidebarCalendarPlaceholder from "./SidebarCalendarPlaceholder.astro";

interface Props {
  config?: {
    calendar?: boolean;
    recentMoments?: boolean;
    randomPosts?: boolean;
  };
  posts?: CollectionEntry<"posts">[];
  moments?: CollectionEntry<"moments">[];
}

const { config = {}, posts = [], moments = [] } = Astro.props;

const locale = (themeConfig.locale as "zh-CN" | "en") || "zh-CN";
const t = getT(locale);

const showCalendar = config.calendar !== false;
const showRecentMoments = config.recentMoments === true;
const showRandomPosts = config.randomPosts === true;

const latestMoments = moments.slice(0, 1).map((moment) => ({
  id: moment.id,
  href: "/moments/",
  date: moment.data.date,
  excerpt: String(moment.body || "")
    .replace(/<[^>]*>/g, "")
    .replace(/\s+/g, " ")
    .trim(),
}));

const shuffledPosts = [...posts]
  .sort(() => Math.random() - 0.5)
  .slice(0, 1)
  .map((post) => ({
    id: post.id,
    href: `/posts/${post.id}/`,
    title: post.data.title,
    description: post.data.description || String(post.body || ""),
  }));

function formatMomentDate(date: Date): string {
  return date.toLocaleDateString(locale, {
    month: "2-digit",
    day: "2-digit",
  });
}

function truncateText(text: string, maxLength: number) {
  if (text.length <= maxLength) {
    return text;
  }

  return `${text.slice(0, maxLength)}...`;
}

const hasCalendarContent = showCalendar;
const hasRecentMomentsContent = showRecentMoments && latestMoments.length > 0;
const hasRandomPostsContent = showRandomPosts && shuffledPosts.length > 0;
const hasRenderedContent =
  hasCalendarContent || hasRecentMomentsContent || hasRandomPostsContent;
---

<aside
  class="layout-extra-column"
  aria-label="secondary sidebar"
  data-extra-sidebar
>
  <div class="layout-extra-column__inner">
    {showCalendar && <SidebarCalendarPlaceholder />}

    {
      hasRecentMomentsContent && (
        <section class="extra-card">
          <div class="extra-card__head">
            <div>
              <p class="extra-card__eyebrow">{t("sidebar.moments.subtitle")}</p>
              <h3>{t("sidebar.moments.title")}</h3>
            </div>
            <span class="extra-card__icon i-ri-chat-quote-line" />
          </div>

          <ul class="extra-list">
            {latestMoments.map((moment) => (
              <li class="extra-list__item">
                <a href={moment.href} class="extra-list__link">
                  <span class="extra-list__meta">
                    {formatMomentDate(moment.date)}
                  </span>
                  <span class="extra-list__title">
                    {truncateText(moment.excerpt || t("moments.noContent"), 38)}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      hasRandomPostsContent && (
        <section class="extra-card">
          <div class="extra-card__head">
            <div>
              <p class="extra-card__eyebrow">
                {t("sidebar.randomPosts.subtitle")}
              </p>
              <h3>{t("sidebar.randomPosts.title")}</h3>
            </div>
            <span class="extra-card__icon i-ri-shuffle-line" />
          </div>

          <ul class="extra-list">
            {shuffledPosts.map((post) => (
              <li class="extra-list__item">
                <a href={post.href} class="extra-list__link">
                  <span class="extra-list__title">
                    {truncateText(post.title, 26)}
                  </span>
                  <span class="extra-list__desc">
                    {truncateText(post.description, 42)}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      !hasRenderedContent && (
        <section class="extra-empty-card">
          <div class="extra-empty-card__head">
            <div>
              <p class="extra-empty-card__eyebrow">
                {t("sidebar.extra.subtitle")}
              </p>
              <h3>{t("sidebar.extra.title")}</h3>
            </div>
            <span class="extra-empty-card__icon i-ri-layout-right-2-line" />
          </div>
          <p class="extra-empty-card__text">{t("sidebar.extra.empty")}</p>
        </section>
      )
    }
  </div>
</aside>

<script is:inline>
  (() => {
    const registryKey = "__hyacineRightSidebarAffix";
    const previous = window[registryKey];

    if (previous?.cleanup) {
      previous.cleanup();
    }

    const roots = Array.from(document.querySelectorAll("[data-extra-sidebar]"));

    if (roots.length === 0) {
      return;
    }

    const computeHeaderHeight = () => {
      const headerElement = document.querySelector("#imgs");
      const navElement = document.querySelector("#nav");
      const wavesElement = document.querySelector("#waves");

      let headerHeight = 0;

      if (headerElement) {
        headerHeight += headerElement.offsetHeight;
      }
      if (navElement) {
        headerHeight += navElement.offsetHeight;
      }
      if (wavesElement) {
        headerHeight += wavesElement.offsetHeight;
      }

      return headerHeight;
    };

    const sync = () => {
      const headerHeight = computeHeaderHeight();
      const shouldAffix =
        window.scrollY > headerHeight - 260 && window.innerWidth >= 1440;

      roots.forEach((root) => {
        const inner = root.querySelector(".layout-extra-column__inner");
        if (!inner) {
          return;
        }

        root.classList.toggle("affix", shouldAffix);
        root.style.minHeight = shouldAffix ? `${inner.offsetHeight}px` : "";
      });
    };

    const onScroll = () => sync();
    const onResize = () => sync();

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onResize, { passive: true });
    requestAnimationFrame(sync);

    window[registryKey] = {
      cleanup() {
        window.removeEventListener("scroll", onScroll);
        window.removeEventListener("resize", onResize);
      },
    };
  })();
</script>

<style>
  .layout-extra-column__inner {
    display: grid;
    gap: 1rem;
  }

  .extra-card,
  .extra-empty-card {
    background:
      linear-gradient(180deg, var(--grey-0) 0%, var(--grey-1) 100%) no-repeat,
      var(--grey-0);
    border: 0.0625rem solid var(--grey-3);
    border-radius: 1rem;
    box-shadow: 0 1rem 1.75rem -1.25rem var(--box-bg-shadow);
    overflow: hidden;
    padding: 1rem;
  }

  .extra-card__head,
  .extra-empty-card__head {
    align-items: flex-start;
    display: flex;
    gap: 0.75rem;
    justify-content: space-between;
    margin-bottom: 0.875rem;
  }

  .extra-card__eyebrow,
  .extra-empty-card__eyebrow {
    color: var(--grey-5);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    margin: 0 0 0.25rem;
    text-transform: uppercase;
  }

  .extra-card h3,
  .extra-empty-card h3 {
    color: var(--grey-8);
    font-size: 1.125rem;
    margin: 0;
  }

  .extra-card__icon,
  .extra-empty-card__icon {
    align-items: center;
    background: var(--nav-bg);
    border-radius: 999px;
    color: var(--grey-8);
    display: inline-flex;
    font-size: 1rem;
    justify-content: center;
    min-height: 2rem;
    min-width: 2rem;
  }

  .extra-list {
    display: grid;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .extra-list__item + .extra-list__item {
    border-top: 0.0625rem dashed var(--grey-3);
  }

  .extra-list__link {
    color: inherit;
    display: grid;
    gap: 0.2rem;
    padding: 0.65rem 0;
    text-decoration: none;
    transition:
      transform 0.25s ease,
      color 0.25s ease;
  }

  .extra-list__link:hover {
    color: var(--color-pink);
    transform: translateX(0.2rem);
  }

  .extra-list__meta {
    color: var(--color-orange);
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1.2;
  }

  .extra-list__title {
    color: var(--grey-7);
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1.6;
  }

  .extra-list__desc {
    color: var(--grey-5);
    font-size: 0.75rem;
    line-height: 1.65;
  }

  .extra-empty-card__text {
    color: var(--grey-5);
    font-size: 0.875rem;
    line-height: 1.9;
    margin: 0;
    padding-top: 0.875rem;
    position: relative;
  }

  .extra-empty-card__text::before {
    background: linear-gradient(90deg, var(--grey-3) 0%, var(--grey-1-a0) 100%);
    content: "";
    height: 0.0625rem;
    left: 0;
    position: absolute;
    right: 0;
    top: 0;
  }

  :global(:root[data-theme="dark"]) .extra-empty-card {
    box-shadow: 0 1rem 2rem -1.5rem rgba(0, 0, 0, 0.65);
  }

  :global(:root[data-theme="dark"]) .extra-card {
    box-shadow: 0 1rem 2rem -1.5rem rgba(0, 0, 0, 0.65);
  }

  :global(:root[data-theme="dark"]) .extra-card__icon,
  :global(:root[data-theme="dark"]) .extra-empty-card__icon {
    color: var(--grey-9);
  }

  :global(:root[data-theme="dark"]) .extra-list__title {
    color: var(--grey-7);
  }
</style>
